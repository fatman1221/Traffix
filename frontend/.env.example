# frontend/.env 或 .env.local（勿提交含密钥的文件）
# https://console.amap.com/dev/key/app
#
# 若浏览器报 USERKEY_PLAT_NOMATCH：说明 Key 的服务平台不含「Web端(JS API)」。
# 处理：控制台 → 应用 → 添加Key → 服务平台务必勾选「Web端(JS API)」；
# 或新建一个仅用于前端的 Key，不要用成「Web服务」等其它类型。
#
# Referer 白名单建议加入：http://localhost:3000 与 http://127.0.0.1:3000
VITE_AMAP_API_KEY=
# 与 Key 同一应用下的「安全密钥」(jscode)；新版 Key 一般必填，否则易出现 Unimplemented type 等错误
VITE_AMAP_SECURITY_JS_CODE=
